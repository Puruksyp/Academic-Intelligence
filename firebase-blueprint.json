{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": [
        "email",
        "createdAt",
        "updatedAt"
      ]
    },
    "Analysis": {
      "title": "Analysis",
      "description": "Paper analysis result",
      "type": "object",
      "properties": {
        "subject": { "type": "string" },
        "year": { "type": "string" },
        "totalQuestions": { "type": "number" },
        "summary": { "type": "string" },
        "topicsJson": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": [
        "subject",
        "summary",
        "topicsJson",
        "status",
        "totalQuestions",
        "createdAt",
        "updatedAt",
        "userId"
      ]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "users/{userId}/analyses/{analysisId}": {
      "schema": "Analysis",
      "description": "Analysis results for each user"
    }
  }
}
